# --- Schemas ---
class QueryRequest(BaseModel):
    language_type: str
    prompt: str
    use_general_knowledge: bool = False
    # THE FIX: Updated to Groq's official active Llama 3.1 model name
    model: str = "llama-3.1-8b-instant" 

class QueryResponse(BaseModel):
    language_type: str
    prompt: str
    model_name: str
    model_response: str
    context: Optional[str] = None

# --- Helper Functions ---
def get_user_count():
    return len(db_state["users"])

def chunk_text(text: str, max_chars: int = 1000):
    """Splits text into manageable pieces for vectorization."""
    paragraphs = [p.strip() for p in text.split('\n\n') if p.strip()]
    final_chunks = []
    for p in paragraphs:
        if len(p) <= max_chars:
            final_chunks.append(p)
        else:
            for i in range(0, len(p), max_chars):
                final_chunks.append(p[i:i+max_chars])
    return final_chunks

def extract_text_from_file(filename: str, content: bytes) -> str:
    """Handles text extraction from .txt, .pdf, and .docx."""
    ext = os.path.splitext(filename)[1].lower()
    
    if ext == ".txt":
        return content.decode('utf-8', errors='ignore')
            
    elif ext == ".pdf":
        if not PyPDF2:
            raise ImportError("PyPDF2 not installed. Use 'pip install PyPDF2'")
        pdf_reader = PyPDF2.PdfReader(io.BytesIO(content))
        return "\n".join([page.extract_text() for page in pdf_reader.pages])
        
    elif ext == ".docx":
        if not DocxDocument:
            raise ImportError("python-docx not installed. Use 'pip install python-docx'")
        doc = DocxDocument(io.BytesIO(content))
        return "\n".join([para.text for para in doc.paragraphs])
        
    elif ext == ".csv":
        return content.decode('utf-8', errors='ignore')
        
    else:
        raise ValueError(f"Unsupported file type: {ext}")

